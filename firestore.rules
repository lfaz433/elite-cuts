rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: checks if user is logged in and belongs to the specified tenant
    function isMemberOfTenant(tenantId) {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId ||
        request.auth.token.tenantId == tenantId
      );
    }

    function isSuperAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "superadmin";
    }

    // 1. Tenants Collection (Public reads for domain resolution, admin write controls)
    match /tenants/{tenantDocId} {
      allow read: if true;
      allow create: if isSuperAdmin() || (request.auth != null && request.auth.uid == request.resource.data.ownerUid);
      allow update, delete: if isSuperAdmin() || (request.auth != null && request.auth.uid == resource.data.ownerUid);
    }

    // 2. Scoped Business Operations Collections
    match /bookings/{bookingId} {
      allow read: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId) || resource.data.tenantId == 'barberboard-demo';
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId) || request.resource.data.tenantId == 'barberboard-demo';
      allow update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
    }

    match /barbers/{barberId} {
      allow read: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId) || resource.data.tenantId == 'barberboard-demo';
      allow create, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
    }

    match /services/{serviceId} {
      allow read: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId) || resource.data.tenantId == 'barberboard-demo';
      allow create, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
    }

    match /sales/{saleId} {
      allow read, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
    }

    match /expenses/{expenseId} {
      allow read, update, delete: if request.auth != null && (
        isSuperAdmin() ||
        request.auth.token.tenantId == resource.data.tenantId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == resource.data.tenantId
      );
      allow create: if request.auth != null && (
        isSuperAdmin() ||
        request.auth.token.tenantId == request.resource.data.tenantId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == request.resource.data.tenantId
      );
    }

    match /deposits/{depositId} {
      allow read, write: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
    }

    // 3. User Profiles Collection (Owner-only access)
    match /users/{userId} {
      allow read, write: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // 4. Notifications Collection (Tenant members OR specific recipient fallback)
    match /notifications/{notificationId} {
      allow read, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId) || 
                                    (request.auth != null && request.auth.uid == resource.data.recipientId);
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId) || 
                                    (request.auth != null && request.auth.uid == request.resource.data.recipientId);
    }

    match /payroll_requests/{requestId} {
      allow read: if isSuperAdmin() || 
        isMemberOfTenant(resource.data.tenantId);
      
      allow create: if request.auth != null && (
        isSuperAdmin() ||
        request.auth.token.tenantId == request.resource.data.tenantId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == request.resource.data.tenantId
      );
      
      allow update, delete: if request.auth != null && (
        isSuperAdmin() ||
        request.auth.token.tenantId == resource.data.tenantId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == resource.data.tenantId
      );
    }

    match /payroll_payments/{paymentId} {
      allow read: if request.auth != null && (
        isSuperAdmin() ||
        request.auth.token.tenantId == resource.data.tenantId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == resource.data.tenantId
      );
      allow create: if request.auth != null && (
        isSuperAdmin() ||
        request.auth.token.tenantId == request.resource.data.tenantId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == request.resource.data.tenantId
      );
    }

    match /manual_payments/{paymentId} {
      allow read, write: if isSuperAdmin();
    }

    // 5. Products collection (demo open)
    match /products/{productId} {
      allow read, write: if true;
    }

    // Updated gallery rules (demo open)
    match /gallery/{galleryId} {
      allow read, write: if true;
    }

    // 6. Unmigrated / Legacy Collections (Locked to prevent data leaks until migrated)
    match /attendance/{document=**} {
      allow read, write: if false;
    }

    match /settlements/{document=**} {
      allow read, write: if false;
    }

    match /business/{document=**} {
      allow read, write: if false;
    }
  }
}
