rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Safely retrieves user data without throwing errors if the document doesn't exist
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : {};
    }

    // Helper: checks if user is logged in and belongs to the specified tenant
    function isMemberOfTenant(tenantId) {
      return request.auth != null && (
        getUserData().tenantId == tenantId ||
        request.auth.token.tenantId == tenantId
      );
    }

    function isSuperAdmin() {
      return request.auth != null && getUserData().role == "superadmin";
    }

    // 1. Tenants Collection (Public reads for domain resolution, admin write controls)
    match /tenants/{tenantId} {
      allow read: if true;
      // Allow create if: superadmin, already a member, OR the authenticated user is the owner
      // (the ownerUid check handles brand-new signups who don't yet have a matching tenantId in their user doc)
      allow create: if isSuperAdmin() 
        || isMemberOfTenant(tenantId)
        || (request.auth != null && request.resource.data.ownerUid == request.auth.uid);
      allow update, delete: if isSuperAdmin() || isMemberOfTenant(tenantId);
    }

    // 1.5 Subdomains Reservation Collection
    match /subdomains/{subdomainName} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isSuperAdmin() || (request.auth != null && resource.data.ownerUid == request.auth.uid);
    }

    // 2. Scoped Business Operations Collections
    match /bookings/{bookingId} {
      allow read: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
      allow create: if true; // guests can create bookings
      allow update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
    }

    match /barbers/{barberId} {
      allow read: if true;
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
      allow update: if isSuperAdmin() || (isMemberOfTenant(resource.data.tenantId) && isMemberOfTenant(request.resource.data.tenantId));
      allow delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
      allow update: if isSuperAdmin() || (isMemberOfTenant(resource.data.tenantId) && isMemberOfTenant(request.resource.data.tenantId));
      allow delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
      allow update: if isSuperAdmin() || (isMemberOfTenant(resource.data.tenantId) && isMemberOfTenant(request.resource.data.tenantId));
      allow delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
    }

    match /gallery/{galleryId} {
      allow read: if true;
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
      allow update: if isSuperAdmin() || (isMemberOfTenant(resource.data.tenantId) && isMemberOfTenant(request.resource.data.tenantId));
      allow delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
    }

    match /sales/{saleId} {
      allow read, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
    }

    match /expenses/{expenseId} {
      allow read, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
    }

    match /deposits/{depositId} {
      allow read, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
    }

    // 3. User Profiles Collection (Owner-only access)
    match /users/{userId} {
      allow read, write: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // 4. Notifications Collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId) || 
                                    (request.auth != null && request.auth.uid == resource.data.recipientId);
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId) || 
                                    (request.auth != null && request.auth.uid == request.resource.data.recipientId);
    }

    // 5. Payroll Collections
    match /payroll_requests/{requestId} {
      allow read, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
    }

    match /payroll_payments/{paymentId} {
      allow read, update, delete: if isSuperAdmin() || isMemberOfTenant(resource.data.tenantId);
      allow create: if isSuperAdmin() || isMemberOfTenant(request.resource.data.tenantId);
    }

    match /manual_payments/{paymentId} {
      allow read, write: if isSuperAdmin();
    }

    // 6. Unmigrated / Legacy Collections
    match /attendance/{document=**} {
      allow read, write: if false;
    }

    match /settlements/{document=**} {
      allow read, write: if false;
    }

    match /business/{document=**} {
      allow read, write: if false;
    }
  }
}
