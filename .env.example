# === Vercel Subdomain Provisioning ===
# The API token to manage Vercel projects (must have at least project-level access).
VERCEL_TOKEN=your_vercel_token_here

# The project ID in Vercel where domains will be attached.
VERCEL_PROJECT_ID=your_vercel_project_id_here

# The team ID in Vercel (optional, required ONLY if the project lives under a Vercel Team).
# Leave blank if using a personal Vercel account.
VERCEL_TEAM_ID=your_vercel_team_id_here

# The main apex domain configured in Vercel (e.g. barberboard.pro).
VITE_MAIN_DOMAIN=barberboard.pro

# === OneSignal (Push Notifications) ===
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key_here
